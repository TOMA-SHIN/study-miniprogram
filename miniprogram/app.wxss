page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  --primary: #4CAF50;
  --primary-light: #81C784;
  --primary-dark: #388E3C;
}

.container {
  padding: 24rpx;
}

.btn-primary {
  background-color: #4CAF50;
  color: #fff;
  border-radius: 8rpx;
  text-align: center;
  padding: 20rpx 0;
}

.btn-danger {
  background-color: #f44336;
  color: #fff;
  border-radius: 8rpx;
  text-align: center;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin: 24rpx 0 16rpx;
}
