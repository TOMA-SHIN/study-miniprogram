.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.form-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.picker {
  height: 80rpx;
  line-height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #999;
}

.picker.selected {
  color: #333;
}

.empty-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  line-height: 80rpx;
  border: 1rpx dashed #4CAF50;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #4CAF50;
  background: #f0f9f0;
}

.empty-tip .arrow {
  font-size: 28rpx;
  color: #999;
}

.tip {
  font-size: 28rpx;
  color: #4CAF50;
  margin-bottom: 24rpx;
  padding: 0 12rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 80rpx;
}

.input-wrap input {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
}

.unit {
  font-size: 28rpx;
  color: #666;
  margin-left: 12rpx;
}

textarea {
  width: 100%;
  height: 200rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 30rpx;
}

.footer {
  margin-top: 40rpx;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #4CAF50;
  color: #fff;
  font-size: 34rpx;
  border-radius: 48rpx;
  border: none;
}

.btn-submit::after {
  border: none;
}

.image-upload-area {
  display: flex;
  align-items: center;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.upload-icon {
  font-size: 48rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #999;
}

.image-preview-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image-preview {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.remove-image-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ff4444;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

/* 深色模式 */
.dark-mode {
  background: #1a1a1a;
}

.dark-mode .form-item {
  background: #2c2c2c;
}

.dark-mode .label,
.dark-mode .picker.selected,
.dark-mode .unit {
  color: #eee;
}

.dark-mode .picker,
.dark-mode .input-wrap,
.dark-mode textarea {
  border-color: #444;
  background: #333;
  color: #eee;
}

.dark-mode .empty-tip {
  background: #2c3a2c;
  color: #81c784;
}

.dark-mode .upload-btn {
  background: #333;
  border-color: #555;
}
