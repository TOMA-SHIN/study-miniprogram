<view class="container {{isDarkMode ? 'dark-mode' : ''}}">
  <view class="form-item">
    <text class="label">选择计划</text>
    <picker mode="selector" range="{{planNames}}" bindchange="onPlanChange" wx:if="{{planNames.length > 0}}">
      <view class="picker {{planIndex >= 0 ? 'selected' : ''}}">
        {{planIndex >= 0 ? planNames[planIndex] : '请选择学习计划'}}
      </view>
    </picker>
    <view class="empty-tip" bindtap="goCreatePlan" wx:if="{{planNames.length === 0}}">
      <text>暂无学习计划，点击前往创建</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="tip" wx:if="{{todayMinutes > 0}}">
    该计划今日已学 {{todayMinutes}} 分钟
  </view>

  <view class="form-item">
    <text class="label">学习时长</text>
    <view class="input-wrap">
      <input type="digit" placeholder="输入学习时长" value="{{minutes}}" bindinput="onMinutesInput" />
      <text class="unit">分钟</text>
    </view>
  </view>

  <view class="form-item">
    <text class="label">学习笔记</text>
    <textarea placeholder="记录今天的学习内容..." value="{{note}}" bindinput="onNoteInput" />
  </view>

  <view class="form-item">
    <text class="label">学习图片（可选）</text>
    <view class="image-upload-area">
      <view wx:if="{{!imageFileID && !imageTempUrl}}" class="upload-btn" bindtap="chooseImage">
        <text class="upload-icon">+</text>
        <text class="upload-text">{{uploadingImage ? '上传中...' : '上传图片'}}</text>
      </view>
      <view wx:else class="image-preview-wrapper">
        <image class="image-preview" src="{{imageTempUrl || ''}}" mode="aspectFill" />
        <view class="remove-image-btn" bindtap="removeImage">×</view>
      </view>
    </view>
  </view>

  <view class="footer">
    <button class="btn-submit" bindtap="submitCheckIn" loading="{{loading}}">确认打卡</button>
  </view>
</view>
