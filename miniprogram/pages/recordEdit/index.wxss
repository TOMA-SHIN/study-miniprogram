.container {
  padding: 30rpx;
}

.plan-header {
  font-size: 32rpx;
  color: #4CAF50;
  margin-bottom: 30rpx;
  font-weight: bold;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.picker,
input,
textarea {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 30rpx;
}

textarea {
  height: 200rpx;
  width: 100%;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #4CAF50;
  color: white;
  border-radius: 48rpx;
  font-size: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}

.submit-btn::after {
  border: none;
}

.image-upload-area {
  display: flex;
  align-items: center;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.upload-icon {
  font-size: 48rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #999;
}

.image-preview-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image-preview {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.remove-image-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ff4444;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

/* 深色模式 */
.dark-mode {
  background-color: #1a1a1a;
}

.dark-mode .plan-header {
  color: #81c784;
}

.dark-mode .label,
.dark-mode .picker,
.dark-mode input,
.dark-mode textarea {
  color: #eee;
}

.dark-mode .picker,
.dark-mode input,
.dark-mode textarea {
  border-color: #444;
  background-color: #333;
}

.dark-mode .upload-btn {
  background: #333;
  border-color: #555;
}
