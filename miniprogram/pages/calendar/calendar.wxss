.container {
  padding: 24rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.nav-btn {
  font-size: 40rpx;
  color: #4CAF50;
  padding: 16rpx;
}

.month-title {
  font-size: 36rpx;
  font-weight: bold;
}

.week-row {
  display: flex;
  margin-bottom: 16rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

.days-grid {
  display: flex;
  flex-wrap: wrap;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 16rpx 0;
}

.day-cell {
  width: 14.28%;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.day-cell.empty {
  visibility: hidden;
}

.day-num {
  font-size: 30rpx;
  color: #333;
}

.day-cell.has-record .day-num {
  color: #4CAF50;
  font-weight: bold;
}

.day-minutes {
  font-size: 20rpx;
  color: #4CAF50;
  margin-top: 4rpx;
}

.legend {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #4CAF50;
  margin-right: 8rpx;
}
