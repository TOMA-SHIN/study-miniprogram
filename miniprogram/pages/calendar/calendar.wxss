.container {
  padding: 24rpx;
}

.month-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.arrow {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 36rpx;
  color: #333;
}

.month-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.week-row {
  display: flex;
  margin-bottom: 16rpx;
}

.week-cell {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-cell {
  width: calc(100% / 7);
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 8rpx;
}

.day-cell.empty {
  background-color: transparent;
}

.day-cell.selected {
  border: 2rpx solid #388E3C;
}

.day-cell.today .day-text {
  color: #f44336;
  font-weight: bold;
}

.day-text {
  font-size: 28rpx;
  color: #333;
}

.detail-panel {
  margin-top: 16rpx;
}

.detail-total {
  font-size: 30rpx;
  color: #4CAF50;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.record-list {
  border-top: 1rpx solid #eee;
}

.record-item {
  display: flex;
  flex-direction: column;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
}

.record-plan {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.record-time {
  font-size: 28rpx;
  color: #4CAF50;
  margin-top: 4rpx;
}

.record-note {
  font-size: 26rpx;
  color: #999;
  margin-top: 4rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 60rpx 0;
  font-size: 28rpx;
}
