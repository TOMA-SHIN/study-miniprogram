<view class="container">
  <view class="calendar-header">
    <text class="nav-btn" bindtap="prevMonth"><</text>
    <text class="month-title">{{year}}年{{month}}月</text>
    <text class="nav-btn" bindtap="nextMonth">></text>
  </view>

  <view class="week-row">
    <text wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this" class="week-day">{{item}}</text>
  </view>

  <view class="days-grid">
    <view wx:for="{{days}}" wx:key="date" class="day-cell {{calendarData[item.date] ? 'has-record' : ''}} {{!item.date ? 'empty' : ''}}">
      <text class="day-num">{{item.day}}</text>
      <text wx:if="{{calendarData[item.date]}}" class="day-minutes">{{calendarData[item.date]}}</text>
    </view>
  </view>

  <view class="legend">
    <view class="legend-item">
      <view class="legend-dot"></view>
      <text>有打卡记录</text>
    </view>
  </view>
</view>
