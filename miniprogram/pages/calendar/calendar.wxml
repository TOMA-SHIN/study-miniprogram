<view class="container">
  <view class="card">
    <view class="month-header">
      <view class="arrow" bindtap="prevMonth">&lt;</view>
      <view class="month-title">{{year}}年{{month}}月</view>
      <view class="arrow" bindtap="nextMonth">&gt;</view>
    </view>
    <view class="week-row">
      <view class="week-cell" wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this">{{item}}</view>
    </view>
    <view class="calendar-grid">
      <view class="day-cell {{item.dateStr ? '' : 'empty'}} {{item.isToday ? 'today' : ''}} {{item.dateStr === selectedDate ? 'selected' : ''}}"
            wx:for="{{calendarDays}}"
            wx:key="dateStr"
            style="background-color: {{item.color}};"
            bindtap="selectDate"
            data-datestr="{{item.dateStr}}">
        <text class="day-text">{{item.day || ''}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{selectedDate}}" class="card detail-panel">
    <view class="section-title">{{selectedDate}} 打卡详情</view>
    <view wx:if="{{dayRecords.length > 0}}">
      <view class="detail-total">总时长: {{selectedTotal}} 分钟</view>
      <view class="record-list">
        <view class="record-item" wx:for="{{dayRecords}}" wx:key="id">
          <text class="record-plan">{{item.planName || item.planId}}</text>
          <text class="record-time">{{item.minutes}} 分钟</text>
          <text class="record-note" wx:if="{{item.note}}">{{item.note}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="empty-tip">当日暂无打卡记录</view>
  </view>

  <view wx:if="{{!hasAnyRecord}}" class="empty-tip">本月暂无打卡记录</view>
</view>
