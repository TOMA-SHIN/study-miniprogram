.container {
  padding: 24rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-group {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #e0e0e0;
  padding: 0 8rpx;
}

.picker {
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #e0e0e0;
  padding: 0 8rpx;
}

.placeholder {
  color: #bbb;
}

.color-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.color-item {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
}

.color-item.selected {
  border-color: #333;
}

.submit-btn {
  margin-top: 40rpx;
  background-color: #4CAF50;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
}
