<view class="container">
  <view class="form-group">
    <text class="label">计划名称</text>
    <input class="input" placeholder="请输入计划名称" value="{{name}}" bindinput="onNameInput" />
  </view>

  <view class="form-group">
    <text class="label">科目</text>
    <picker bindchange="onSubjectChange" value="{{subjectIndex}}" range="{{subjects}}" range-key="name">
      <view class="picker {{subjectIndex === -1 ? 'placeholder' : ''}}">
        {{subjectIndex > -1 ? subjects[subjectIndex].name : '请选择科目'}}
      </view>
    </picker>
  </view>

  <view class="form-group">
    <text class="label">目标时长（分钟/天）</text>
    <input class="input" type="number" placeholder="请输入目标时长" value="{{targetMinutes}}" bindinput="onMinutesInput" />
  </view>

  <view class="form-group">
    <text class="label">颜色标记</text>
    <view class="color-list">
      <view
        class="color-item {{color === item ? 'selected' : ''}}"
        wx:for="{{colorOptions}}"
        wx:key="*this"
        style="background-color: {{item}};"
        bindtap="onColorSelect"
        data-color="{{item}}"
      ></view>
    </view>
  </view>

  <view class="form-group">
    <text class="label">开始日期</text>
    <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
      <view class="picker {{!startDate ? 'placeholder' : ''}}">
        {{startDate || '请选择开始日期'}}
      </view>
    </picker>
  </view>

  <view class="form-group">
    <text class="label">结束日期（可选）</text>
    <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
      <view class="picker {{!endDate ? 'placeholder' : ''}}">
        {{endDate || '请选择结束日期'}}
      </view>
    </picker>
  </view>

  <button class="submit-btn" bindtap="submit">保存</button>
</view>
