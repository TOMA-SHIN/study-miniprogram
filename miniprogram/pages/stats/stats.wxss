.container {
  padding: 24rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.tab-bar {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-active {
  color: #4CAF50;
  font-weight: bold;
  background-color: rgba(76, 175, 80, 0.08);
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 80rpx 0;
}

.empty-small {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  padding: 32rpx 0;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.stats-card {
  flex: 1;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 32rpx 0;
  margin-right: 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.stats-card:last-child {
  margin-right: 0;
}

.stats-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
}

.streak-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.streak-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.streak-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.streak-label {
  font-size: 26rpx;
  color: #999;
}

.streak-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #eee;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin: 32rpx 0 16rpx;
}

.bar-row {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.bar-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.bar-track {
  height: 24rpx;
  background-color: #e8e8e8;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.bar-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.3s ease;
}

.bar-color-0 { background-color: #4CAF50; }
.bar-color-1 { background-color: #2196F3; }
.bar-color-2 { background-color: #FF9800; }
.bar-color-3 { background-color: #9C27B0; }
.bar-color-4 { background-color: #F44336; }

.bar-value {
  font-size: 24rpx;
  color: #999;
}

.record-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.record-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.record-date {
  font-size: 28rpx;
  color: #333;
}

.record-minutes {
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: 500;
}

.record-note {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dark-mode {
  background-color: #1a1a1a;
}

.dark-mode .tab-bar,
.dark-mode .stats-card,
.dark-mode .streak-card,
.dark-mode .bar-row,
.dark-mode .record-item {
  background-color: #2c2c2c;
}

.dark-mode .tab-item {
  color: #aaa;
}

.dark-mode .streak-value,
.dark-mode .bar-label,
.dark-mode .record-date,
.dark-mode .section-title {
  color: #eee;
}

.dark-mode .stats-label,
.dark-mode .streak-label,
.dark-mode .bar-value,
.dark-mode .record-note,
.dark-mode .empty-tip,
.dark-mode .empty-small {
  color: #aaa;
}

.dark-mode .streak-divider {
  background-color: #444;
}

.dark-mode .bar-track {
  background-color: #444;
}
