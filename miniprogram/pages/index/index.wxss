.container {
  padding: 24rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.user-header {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.user-avatar-wrap {
  margin-right: 20rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  background-color: #4CAF50;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-nick {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 24rpx;
  color: #999;
}

.stats-card {
  background-color: #4CAF50;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
}

.stats-main {
  display: flex;
  align-items: baseline;
}

.stats-number {
  font-size: 72rpx;
  font-weight: bold;
  margin-right: 12rpx;
}

.stats-unit {
  font-size: 32rpx;
  opacity: 0.9;
}

.stats-side {
  text-align: right;
}

.streak-text {
  font-size: 28rpx;
  opacity: 0.95;
}

.action-cards {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
  gap: 20rpx;
}

.action-card {
  flex: 1;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 36rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.checkin-card {
  border: 2rpx solid #4CAF50;
}

.stats-card-btn {
  border: 2rpx solid #2196F3;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.checkin-card .action-icon {
  color: #4CAF50;
  font-weight: bold;
}

.action-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #999;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 48rpx 0;
}

.record-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.record-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.record-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.record-minutes {
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: 500;
}

.record-note {
  font-size: 26rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.footer-link {
  margin-top: 40rpx;
  text-align: center;
  color: #666;
  font-size: 28rpx;
  padding: 24rpx;
}

/* 深色模式 */
.dark-mode {
  background-color: #1a1a1a;
}

.dark-mode .user-header,
.dark-mode .action-card,
.dark-mode .record-item {
  background-color: #2c2c2c;
}

.dark-mode .user-nick,
.dark-mode .action-title,
.dark-mode .section-title,
.dark-mode .record-name {
  color: #eee;
}

.dark-mode .user-desc,
.dark-mode .action-desc,
.dark-mode .empty-tip,
.dark-mode .record-note,
.dark-mode .footer-link {
  color: #aaa;
}

.dark-mode .record-minutes {
  color: #66bb6a;
}
