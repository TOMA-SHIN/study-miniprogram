<view class="container {{isDarkMode ? 'dark-mode' : ''}}">
  <!-- 未登录状态 -->
  <view class="profile-header login-header" wx:if="{{!isLoggedIn}}">
    <view class="avatar-wrap">
      <view class="avatar avatar-placeholder large">学</view>
    </view>
    <text class="login-tip">登录后查看学习数据</text>
    <button class="login-btn" bindtap="handleLogin">点击登录</button>
  </view>

  <!-- 已登录状态 -->
  <view class="profile-header" wx:if="{{isLoggedIn}}">
    <view class="avatar-wrap">
      <image wx:if="{{userInfo.avatarUrl}}" class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <view wx:else class="avatar avatar-placeholder">学</view>
    </view>
    <text class="nick-name">{{userInfo.nickName || '学习打卡'}}</text>
  </view>

  <view class="stats-section" wx:if="{{isLoggedIn}}">
    <view class="stats-grid">
      <view class="stats-item">
        <text class="stats-num">{{stats.totalMinutes}}</text>
        <text class="stats-label">总时长(分)</text>
      </view>
      <view class="stats-item">
        <text class="stats-num">{{stats.totalRecords}}</text>
        <text class="stats-label">总记录</text>
      </view>
      <view class="stats-item">
        <text class="stats-num">{{stats.streak}}</text>
        <text class="stats-label">连续打卡(天)</text>
      </view>
      <view class="stats-item">
        <text class="stats-num">{{stats.longestStreak}}</text>
        <text class="stats-label">最长连续(天)</text>
      </view>
    </view>
  </view>

  <view class="menu-section" wx:if="{{isLoggedIn}}">
    <view class="menu-item" bindtap="goStats">
      <text class="menu-text">学习统计</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-title">设置</view>
    <view class="menu-item">
      <text class="menu-text">深色模式</text>
      <switch checked="{{isDarkMode}}" bindchange="toggleDarkMode" color="#4CAF50" />
    </view>
    <view class="menu-item logout-item" bindtap="handleLogout" wx:if="{{isLoggedIn}}">
      <text class="menu-text logout-text">退出登录</text>
    </view>
  </view>
</view>
