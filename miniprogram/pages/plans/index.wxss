.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #4CAF50;
  color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 32rpx;
}

.add-icon {
  font-size: 40rpx;
  margin-right: 8rpx;
}

.empty-state {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.plan-card {
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.card-main {
  padding: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.color-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.plan-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
}

.status-ongoing {
  background-color: #4CAF50;
}

.status-notstarted {
  background-color: #999;
}

.status-ended {
  background-color: #bbb;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  color: #999;
  margin-right: 8rpx;
}

.subject-tag {
  background-color: #E8F5E9;
  color: #4CAF50;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  border-top: 1rpx solid #f0f0f0;
  padding: 16rpx 24rpx;
}

.delete-btn {
  color: #F44336;
  font-size: 26rpx;
}

.dark-mode {
  background-color: #1a1a1a;
}

.dark-mode .plan-card,
.dark-mode .empty-state {
  background-color: #2c2c2c;
}

.dark-mode .plan-name,
.dark-mode .info-row {
  color: #eee;
}

.dark-mode .label {
  color: #aaa;
}

.dark-mode .subject-tag {
  background-color: #1b3a1c;
  color: #81c784;
}

.dark-mode .card-footer {
  border-top-color: #3a3a3a;
}
